{
  "name": "rag-pipeline",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "lint": "eslint src tests --ext .ts",
    "build": "pnpm --filter @workspaces/packages/errors run build && node esbuild.config.mjs"
  },
  "dependencies": {
    "@workspaces/packages/errors": "workspace:*",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/express": "^5.0.5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
