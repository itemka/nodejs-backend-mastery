{
  "name": "nodejs-backend-mastery",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r run --if-present build",
    "typecheck": "pnpm -r run --if-present typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run --if-present test",
    "validate": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test",
    "validate:all": "pnpm run validate && pnpm run check:secrets && pnpm run check:adapters && pnpm run build",
    "validate:changed": "node scripts/validate-changed.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:adapters": "node scripts/check-adapters.mjs",
    "sync-mcp": "node scripts/sync-mcp-to-codex.mjs",
    "postinstall": "node scripts/sync-mcp-to-codex.mjs --quiet-missing || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@workspaces/cli-output": "workspace:*",
    "eslint": "^9.39.4",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.2",
    "shell-quote": "^1.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "typescript-language-server": "^5.3.0"
  }
}
