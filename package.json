{
  "name": "nodejs-backend-mastery",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter ./workspaces/apps/*... run build",
    "typecheck": "pnpm -r run --if-present typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run --if-present test",
    "sync-mcp": "node scripts/sync-mcp-to-codex.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "pnpm": {
    "overrides": {
      "router>path-to-regexp": "^8.4.2",
      "ts-declaration-location>picomatch": "^4.0.4",
      "vitest>picomatch": "^4.0.4"
    }
  }
}
