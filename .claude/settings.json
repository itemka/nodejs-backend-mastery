{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm --filter * run typecheck)",
      "Bash(pnpm --filter * run lint)",
      "Bash(pnpm exec prettier --check *)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run format:check)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run validate:changed)",
      "Bash(pnpm run check:secrets)",
      "Bash(pnpm run check:adapters)",
      "Bash(pnpm run sync-mcp)",
      "Bash(node scripts/check-secrets.mjs)",
      "Bash(node scripts/check-adapters.mjs)",
      "Bash(node scripts/sync-mcp-to-codex.mjs)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.agents/hooks/before-bash.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.agents/hooks/after-edit.mjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.agents/hooks/inject-git-context.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.agents/hooks/stop-checks.mjs\""
          }
        ]
      }
    ]
  }
}
